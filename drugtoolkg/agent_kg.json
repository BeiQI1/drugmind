  "graph": {
    "nodes": {
      "IntentAgent": {
        "layer": "Interaction",
        "description": "Parses user input and manages dialogue state.",
        "tools": [
          "Transformers",
          "LangChain",
          "FastAPI",
          "Gradio",
          "Uvicorn"
        ],
        "inputs": [
          "User Text",
          "PDB ID",
          "SMILES",
          "Files"
        ],
        "outputs": [
          "Intent JSON",
          "Task Parameters"
        ],
        "connections": {
          "to": [
            "TargetAgent",
            "RAGAgent"
          ],
          "type": "Control Flow"
        },
        "knowledge_base": {
          "concepts": [
            "Intent Classification",
            "Entity Extraction",
            "Dialogue Management"
          ],
          "memory_type": "Long-term Dialogue Memory (Redis)"
        }
      },
      "TargetAgent": {
        "layer": "Data_Preparation",
        "description": "Prepares protein target structures.",
        "tools": [
          "ValidatePDB",
          "DownloadPDB",
          "FetchMetadata",
          "PDBFixer",
          "CleanPDB",
          "ExtractLigand",
          "RDKit",
          "fpocket",
          "CalculateCenterFromResidues",
          "Finish"
        ],
        "inputs": [
          "PDB ID",
          "PDB File"
        ],
        "outputs": [
          "Cleaned PDB",
          "Pocket Coordinates (.pqr/.pdb)",
          "Pocket Vector"
        ],
        "connections": {
          "from": [
            "IntentAgent"
          ],
          "to": [
            "GeneratorAgent",
            "EvaluatorAgent"
          ],
          "type": "Data Flow"
        },
        "knowledge_base": {
          "concepts": [
            "Protein Structure",
            "Binding Pocket",
            "Residue Analysis"
          ],
          "validation_rules": [
            "Check missing atoms",
            "Check protonation"
          ]
        }
      },
      "RAGAgent": {
        "layer": "Data_Preparation",
        "description": "Retrieves external knowledge and literature.",
        "tools": [
          "ragatouille",
          "faiss",
          "pubchempy",
          "biopython"
        ],
        "inputs": [
          "Search Query",
          "Target Name",
          "Molecule ID"
        ],
        "outputs": [
          "Literature Summary",
          "Reference List",
          "Similar Molecules"
        ],
        "connections": {
          "from": [
            "IntentAgent",
            "ConditionAgent"
          ],
          "to": [
            "ReportAgent"
          ],
          "type": "Information Flow"
        },
        "knowledge_base": {
          "sources": [
            "PubChem",
            "ChEMBL",
            "BindingDB",
            "Literature"
          ],
          "memory_type": "Semantic Memory (FAISS)"
        }
      },
      "EvaluatorAgent": {
        "layer": "Evaluation",
        "description": "Evaluates generated molecules.",
        "tools": [
          "CalculateQED",
          "CalculateSA",
          "CalculateLipinski",
          "CalculateToxicity",
          "CalculateDiversity",
          "RunStandardEvaluation",
          "RunDocking",
          "ValidatePose",
          "AnalyzeInteractions",
          "FilterMolecules",
          "Finish"
        ],
        "inputs": [
          "Molecules (SMILES/SDF)",
          "Target Structure"
        ],
        "outputs": [
          "Score Matrix (QED, SA, Affinity, ADMET)"
        ],
        "connections": {
          "from": [
            "GeneratorAgents"
          ],
          "to": [
            "CoordinatorAgent",
            "ReportAgent"
          ],
          "type": "Feedback Flow"
        },
        "knowledge_base": {
          "metrics": [
            "Drug-likeness",
            "Synthesizability",
            "Binding Affinity",
            "Toxicity"
          ],
          "adaptive_thresholds": true
        }
      },
      "CoordinatorAgent": {
        "layer": "Reasoning_Control",
        "description": "Manages the generation-evaluation loop and optimization.",
        "tools": [
          "Accelerate",
          "WandB",
          "LangGraph",
          "LangChain"
        ],
        "inputs": [
          "Evaluation Scores",
          "Generation History"
        ],
        "outputs": [
          "Optimization Strategy",
          "Stop Signal",
          "Refined Conditions"
        ],
        "connections": {
          "from": [
            "EvaluatorAgent"
          ],
          "to": [
            "GeneratorAgent"
          ],
          "type": "Control Loop"
        },
        "knowledge_base": {
          "strategies": [
            "PPO",
            "GFlowNet",
            "Genetic Algorithm"
          ],
          "memory_type": "Global State Memory"
        }
      },
      "SynthesisAgent": {
        "layer": "Synthesis",
        "description": "Analyzes synthetic accessibility and plans routes.",
        "tools": [
          "LoadCandidates",
          "SelectTopN",
          "RunRetrosynthesis",
          "RunAiZynth",
          "GenerateSynthesisReport",
          "AnalyzeRouteComplexity",
          "Finish"
        ],
        "inputs": [
          "Selected Molecules"
        ],
        "outputs": [
          "Synthesis Routes",
          "Complexity Score"
        ],
        "connections": {
          "from": [
            "CoordinatorAgent",
            "EvaluatorAgent"
          ],
          "to": [
            "ReportAgent"
          ],
          "type": "Data Flow"
        },
        "knowledge_base": {
          "concepts": [
            "Retrosynthesis",
            "Reaction Templates",
            "Building Blocks"
          ]
        }
      },
      "ReportAgent": {
        "layer": "Interaction",
        "description": "Generates final reports and visualizations.",
        "tools": [
          "LoadData",
          "RetrieveContext",
          "GenerateDistributionPlot",
          "GenerateCorrelationPlot",
          "GenerateHeatmap",
          "GenerateMoleculeGrid",
          "GenerateSimilarityNetwork",
          "GetTable",
          "AssessToxicity",
          "WriteSection",
          "Finish"
        ],
        "inputs": [
          "All Results",
          "Safety Checks"
        ],
        "outputs": [
          "PDF/HTML Report",
          "Visualizations"
        ],
